# === SMTP (Gmail) ===
# Gmail erfordert ein App-Passwort, kein normales Login-Passwort.
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deinkonto@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_USE_TLS=true

# === Mail ===
MAIL_FROM=deinkonto@gmail.com
MAIL_TO=de.ka@gmx.net
MAIL_SUBJECT_PREFIX=[Value-Screening DAX/MDAX]

# === Universum & Reporting ===
UNIVERSE=DAX_MDAX
TOP_N=20
BOTTOM_N=10
MIN_MARKET_CAP=300000000

# === Scoring (optional, Defaults sind sinnvoll) ===
VALUE_WEIGHT=0.6
QUALITY_WEIGHT=0.4
DEFAULT_TAX_RATE=0.27

# === Operatives ===
# Cron-Schedule (Container-intern, m h dom mon dow). Default = Sa 07:30.
CRON_SCHEDULE=30 7 * * 6

# Optional: Healthchecks.io Endpoint fuer Dead-Man's-Switch
# (Account anlegen, Check erstellen, URL kopieren)
# HEALTHCHECK_URL=https://hc-ping.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

TZ=Europe/Berlin
